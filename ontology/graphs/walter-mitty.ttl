@base <https://monomyth.metamuses.org/graph/> .
@prefix monomyth: <https://monomyth.metamuses.org/ontology#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <http://schema.org/> .
@prefix wd: <http://www.wikidata.org/entity/> .

# ==============================================================================
# THE SECRET LIFE OF WALTER MITTY (2013)
# ==============================================================================

<walter-mitty> a monomyth:NarrativeWork, schema:CreativeWork ;
    rdfs:label "The Secret Life of Walter Mitty (2013)"@en ;
    dcterms:title "The Secret Life of Walter Mitty"@en ;
    dcterms:creator "Ben Stiller" ;
    schema:genre "Adventure"@en, "Drama"@en ;
    owl:sameAs wd:Q3522637 ;
    monomyth:interpretedBy <walter-mitty/monomyths/mitty-journey> ;
    rdfs:comment """A modern narrative in which an introverted man escapes into elaborate fantasies before undertaking a real-world journey that transforms his identity."""@en .

# --- Monomyth Expression -------------------------------------------------------

# --- Monomyth Expression -------------------------------------------------------

<walter-mitty/monomyths/mitty-journey> a monomyth:MonomythExpression ;
    rdfs:label "Walter Mitty's Psychological Hero Journey"@en ;
    monomyth:interprets <walter-mitty> ;
    monomyth:hasHero <walter-mitty/characters/walter> ;
    monomyth:hasCharacter 
        <walter-mitty/characters/walter>,
        <walter-mitty/characters/cheryl>,
        <walter-mitty/characters/sean>,
        <walter-mitty/characters/ted> ;
    monomyth:hasStageRealization 
        <walter-mitty/stages/call>,
        <walter-mitty/stages/refusal>,
        <walter-mitty/stages/supernatural-aid>,
        <walter-mitty/stages/threshold>,
        <walter-mitty/stages/belly-of-the-whale>,
        <walter-mitty/stages/trials>,
        <walter-mitty/stages/goddess>,
        <walter-mitty/stages/temptress>,
        <walter-mitty/stages/atonement>,
        <walter-mitty/stages/apotheosis>,
        <walter-mitty/stages/boon>,
        <walter-mitty/stages/refusal-of-the-return>, 
        <walter-mitty/stages/magic-flight>,          
        <walter-mitty/stages/rescue-from-without>,   
        <walter-mitty/stages/crossing-return-threshold>, 
        <walter-mitty/stages/master-of-two-worlds>,  
        <walter-mitty/stages/freedom-to-live> .     

# --- Characters ---------------------------------------------------------------

<walter-mitty/characters/walter> a monomyth:Character ;
    rdfs:label "Walter Mitty"@en ;
    monomyth:embodiesArchetype monomyth:Hero .

<walter-mitty/characters/sean> a monomyth:Character ;
    rdfs:label "Sean O'Connell"@en ;
    monomyth:embodiesArchetype monomyth:Mentor, monomyth:Herald .

<walter-mitty/characters/cheryl> a monomyth:Character ;
    rdfs:label "Cheryl Melhoff"@en ;
    monomyth:embodiesArchetype monomyth:Ally .

<walter-mitty/characters/ted> a monomyth:Character ;
    rdfs:label "Ted Hendricks"@en ;
    monomyth:embodiesArchetype monomyth:Shadow .

# --- Stage Realizations -------------------------------------------------------

<walter-mitty/stages/call> a monomyth:StageRealization ;
    rdfs:label "Missing Negative 25"@en ;
    monomyth:realizesStage monomyth:TheCallToAdventure ;
    monomyth:hasFitQuality monomyth:StrongFit ;
    monomyth:stageRealizationOrder 1 ;
    monomyth:realizationDescription """Walter Mitty is tasked with locating the missing negative 25, intended for the final cover of Life magazine. 
    This demand disrupts his passive routine and forces him into a situation where inaction is no longer viable."""@en .

<walter-mitty/stages/refusal> a monomyth:StageRealization ;
    rdfs:label "Retreat into Fantasy"@en ;
    monomyth:realizesStage monomyth:RefusalOfTheCall ;
    monomyth:hasFitQuality monomyth:StrongFit ;
    monomyth:stageRealizationOrder 2 ;
    monomyth:realizationDescription """Rather than immediately acting, Walter retreats into elaborate daydreams in which he performs heroic feats. 
    These fantasies replace action with imagined competence, delaying engagement with reality."""@en .

<walter-mitty/stages/supernatural-aid> a monomyth:StageRealization ;
    rdfs:label "Absent Mentor Figure"@en ;
    monomyth:realizesStage monomyth:SupernaturalAid ;
    monomyth:hasFitQuality monomyth:AbsentFit ;
    monomyth:stageRealizationOrder 3 ;
    monomyth:realizationDescription """No direct mentor intervenes to guide Walter. Sean O’Connell exists only indirectly through photographs and reputation, 
    offering no explicit instruction or magical aid. The guidance typical of this stage is structurally missing."""@en ;
    monomyth:hasNarrativeDivergence <walter-mitty/divergences/narrative/absent-mentor> .

<walter-mitty/stages/threshold> a monomyth:StageRealization ;
    rdfs:label "Departure to Greenland"@en ;
    monomyth:realizesStage monomyth:TheCrossingOfTheFirstThreshold ;
    monomyth:hasFitQuality monomyth:StrongFit ;
    monomyth:stageRealizationOrder 4 ;
    monomyth:realizationDescription """Walter leaves New York and travels to Greenland, marking his first decisive break from passive existence into active engagement with the external world."""@en ;
    monomyth:hasSemioticDivergence <walter-mitty/divergences/semiotic/imagination-as-world> ;
    monomyth:hasSequentialDivergence <walter-mitty/divergences/sequential/soft-threshold> .

<walter-mitty/stages/belly-of-the-whale> a monomyth:StageRealization ;
    rdfs:label "Belly of the Whale (Internalized Condition)"@en ;
    monomyth:realizesStage monomyth:TheBellyOfTheWhale ;
    monomyth:involvesCharacter <walter-mitty/characters/walter> ;
    monomyth:hasFitQuality monomyth:WeakFit ;
    monomyth:stageRealizationOrder 5 ;
    monomyth:realizationDescription """Walter Mitty’s 'belly of the whale' is not a discrete event but an ongoing condition of existential enclosure. 
    At the beginning of the narrative, he exists in a state of social invisibility, passivity, and psychological retreat, 
    where daydreams replace action and identity is suspended rather than expressed. 
    This condition functions as a symbolic engulfment: Walter is effectively 'swallowed' by his own un-lived life, 
    cut off from agency and authentic experience. 

    Unlike the classical monomyth, where the hero enters the belly after crossing the threshold, 
    Walter begins the story already inside it. The journey that follows is therefore not a descent into darkness 
    but an emergence from it, reversing the traditional structure of symbolic death and rebirth."""@en ;
    monomyth:hasSemioticDivergence <walter-mitty/divergences/semiotic/preexisting-engulfment> ;
    monomyth:hasSequentialDivergence <walter-mitty/divergences/sequential/reversed-whale-order> .

<walter-mitty/stages/trials> a monomyth:StageRealization ;
    rdfs:label "Real-World Challenges"@en ;
    monomyth:realizesStage monomyth:TheRoadOfTrials ;
    monomyth:hasFitQuality monomyth:StrongFit ;
    monomyth:stageRealizationOrder 6 ;
    monomyth:realizationDescription """Walter undergoes a sequence of real-world challenges, including jumping into the ocean from a helicopter, navigating unfamiliar landscapes, and traveling across continents. 
    These experiences replace imagined heroism with lived action."""@en .

<walter-mitty/stages/goddess> a monomyth:StageRealization ;
    rdfs:label "Connection with Cheryl"@en ;
    monomyth:realizesStage monomyth:TheMeetingWithTheGoddess ;
    monomyth:hasFitQuality monomyth:WeakFit ;
    monomyth:stageRealizationOrder 7 ;
    monomyth:realizationDescription """Cheryl represents emotional grounding and authentic connection. However, she does not function as a transcendent or mythic figure, 
    making this stage a grounded reinterpretation of the archetype."""@en .

<walter-mitty/stages/temptress> a monomyth:StageRealization ;
    rdfs:label "Temptation of Fantasy"@en ;
    monomyth:realizesStage monomyth:WomanAsTheTemptress ;
    monomyth:hasFitQuality monomyth:WeakFit ;
    monomyth:stageRealizationOrder 8 ;
    monomyth:realizationDescription """Temptation appears not as a person but as Walter’s tendency to retreat into fantasy. 
    The danger lies in disengagement from reality rather than sensual distraction."""@en .

<walter-mitty/stages/atonement> a monomyth:StageRealization ;
    rdfs:label "Encounter with Sean"@en ;
    monomyth:realizesStage monomyth:AtonementWithTheFather ;
    monomyth:hasFitQuality monomyth:WeakFit ;
    monomyth:stageRealizationOrder 9 ;
    monomyth:realizationDescription """Walter meets Sean O’Connell, who affirms his value. This interaction lacks hierarchy or authority, 
    functioning instead as recognition rather than submission."""@en .

<walter-mitty/stages/apotheosis> a monomyth:StageRealization ;
    rdfs:label "Moment of Understanding"@en ;
    monomyth:realizesStage monomyth:Apotheosis ;
    monomyth:hasFitQuality monomyth:StrongFit ;
    monomyth:stageRealizationOrder 10 ;
    monomyth:realizationDescription """Walter abandons the need to capture the perfect photograph and instead experiences the moment directly, 
    achieving a shift in perception and self-understanding."""@en .

<walter-mitty/stages/boon> a monomyth:StageRealization ;
    rdfs:label "Walter as the Photograph"@en ;
    monomyth:realizesStage monomyth:TheUltimateBoon ;
    monomyth:hasFitQuality monomyth:PerfectFit ;
    monomyth:stageRealizationOrder 11 ;
    monomyth:realizationDescription """The missing photograph is revealed to be an image of Walter himself, symbolizing recognition of his own value."""@en ;
    monomyth:hasSemioticDivergence <walter-mitty/divergences/semiotic/self-as-boon> .


<walter-mitty/stages/refusal-of-the-return> a monomyth:StageRealization ;
    rdfs:label "No Refusal of the Return"@en ;
    monomyth:realizesStage monomyth:RefusalOfTheReturn ;
    monomyth:involvesCharacter <walter-mitty/characters/walter> ;
    monomyth:hasFitQuality monomyth:AbsentFit ;
    monomyth:stageRealizationOrder 12 ;
    monomyth:realizationDescription """Walter Mitty does not resist returning from the extraordinary world because his journey does not produce a transcendent realm separate from ordinary life. 
    Unlike classical heroes who hesitate to leave enlightenment or bliss, Walter’s transformation is oriented toward reintegration from the outset. 
    The experiences he gains—confidence, presence, and agency—are meaningful precisely because they belong in his everyday life. 
    There is no tension between worlds, and therefore no reluctance to return."""@en ;
    monomyth:hasNarrativeDivergence <walter-mitty/divergences/narrative/no-transcendent-realm> .

<walter-mitty/stages/magic-flight> a monomyth:StageRealization ;
    rdfs:label "No Magic Flight"@en ;
    monomyth:realizesStage monomyth:TheMagicFlight ;
    monomyth:involvesCharacter <walter-mitty/characters/walter> ;
    monomyth:hasFitQuality monomyth:AbsentFit ;
    monomyth:stageRealizationOrder 13 ;
    monomyth:realizationDescription """There is no dramatic escape or pursuit following the attainment of the boon. 
    Walter’s journey lacks a climactic flight because the narrative avoids constructing the extraordinary world as hostile or something to escape from. 
    His return unfolds naturally through travel rather than conflict, and the absence of pursuit reflects the film’s grounding in realism and internal transformation rather than mythic antagonism."""@en ;
    monomyth:hasSequentialDivergence <walter-mitty/divergences/sequential/no-escape-structure> .

<walter-mitty/stages/rescue-from-without> a monomyth:StageRealization ;
    rdfs:label "No Rescue from Without"@en ;
    monomyth:realizesStage monomyth:RescueFromWithout ;
    monomyth:involvesCharacter <walter-mitty/characters/walter> ;
    monomyth:hasFitQuality monomyth:AbsentFit ;
    monomyth:stageRealizationOrder 14 ;
    monomyth:realizationDescription """Walter is not brought back by an external force or guide because his transformation is self-driven. 
    Classical heroes often require assistance to return from the threshold, symbolizing dependence on community or divine aid. 
    In contrast, Walter’s arc emphasizes autonomy: the same individual who was once passive now actively navigates his return, 
    eliminating the need for rescue and reinforcing the narrative’s focus on self-actualization."""@en ;
    monomyth:hasNarrativeDivergence <walter-mitty/divergences/narrative/self-driven-return> .

<walter-mitty/stages/crossing-return-threshold> a monomyth:StageRealization ;
    rdfs:label "Crossing the Return Threshold (Internalized)"@en ;
    monomyth:realizesStage monomyth:TheCrossingOfTheReturnThreshold ;
    monomyth:involvesCharacter <walter-mitty/characters/walter> ;
    monomyth:hasFitQuality monomyth:WeakFit ;
    monomyth:stageRealizationOrder 15 ;
    monomyth:realizationDescription """Walter’s return to New York and his workplace constitutes a subdued version of the return threshold. 
    Rather than struggling to translate mystical knowledge into social terms, he re-enters the same environment transformed in attitude rather than status. 
    The challenge is not communication of cosmic truth but quiet behavioral change—confidence, decisiveness, and presence. 
    The threshold is therefore internal rather than structural, marking a shift in being rather than a confrontation between incompatible worlds."""@en ;
    monomyth:hasSemioticDivergence <walter-mitty/divergences/semiotic/internalized-threshold> .

<walter-mitty/stages/master-of-two-worlds> a monomyth:StageRealization ;
    rdfs:label "Collapse of Two Worlds"@en ;
    monomyth:realizesStage monomyth:MasterOfTheTwoWorlds ;
    monomyth:involvesCharacter <walter-mitty/characters/walter> ;
    monomyth:hasFitQuality monomyth:AbsentFit ;
    monomyth:stageRealizationOrder 16 ;
    monomyth:realizationDescription """Walter does not become a master of two distinct worlds because the film dissolves the boundary between them. 
    His initial “inner world” of fantasy is not a sacred or transcendent realm but a symptom of disconnection from reality. 
    As he transforms, imagination and reality are integrated rather than balanced as separate domains. 
    The classical duality collapses into a single, unified mode of being grounded in presence."""@en ;
    monomyth:hasSemioticDivergence <walter-mitty/divergences/semiotic/world-collapse> .

<walter-mitty/stages/freedom-to-live> a monomyth:StageRealization ;
    rdfs:label "Freedom to Live"@en ;
    monomyth:realizesStage monomyth:FreedomToLive ;
    monomyth:involvesCharacter <walter-mitty/characters/walter> ;
    monomyth:hasFitQuality monomyth:StrongFit ;
    monomyth:stageRealizationOrder 17 ;
    monomyth:realizationDescription """Walter achieves a grounded version of freedom to live, expressed through presence, courage, and acceptance of uncertainty. 
    His transformation is not mystical but existential: he no longer escapes into fantasy or avoids risk, 
    but engages directly with life as it unfolds. This freedom is quiet and continuous rather than triumphant, 
    aligning the monomyth’s final stage with modern psychological realism."""@en .

# --- Divergences for Return Arc -----------------------------------------------

<walter-mitty/divergences/narrative/no-transcendent-realm> a monomyth:NarrativeDivergence ;
    rdfs:label "No Transcendent Realm divergence"@en ;
    monomyth:divergenceOf <walter-mitty/stages/refusal-of-the-return> ;
    monomyth:divergesFrom monomyth:RefusalOfTheReturn ;
    monomyth:divergenceRationale """The narrative does not construct a separate transcendent realm that the hero must leave behind. 
    Walter’s journey unfolds within the real world, and transformation occurs through engagement rather than escape. 
    Without a distinct sacred space, the structural basis for refusing the return disappears entirely."""@en .

<walter-mitty/divergences/sequential/no-escape-structure> a monomyth:SequentialDivergence ;
    rdfs:label "No Escape Structure divergence"@en ;
    monomyth:divergenceOf <walter-mitty/stages/magic-flight> ;
    monomyth:divergesFrom monomyth:TheMagicFlight ;
    monomyth:divergenceRationale """The narrative eliminates the escape-and-pursuit structure typical of the magic flight. 
    Instead of fleeing with the boon, Walter simply travels back, reflecting a shift from mythic danger to experiential continuity."""@en .

<walter-mitty/divergences/narrative/self-driven-return> a monomyth:NarrativeDivergence ;
    rdfs:label "Self-Driven Return divergence"@en ;
    monomyth:divergenceOf <walter-mitty/stages/rescue-from-without> ;
    monomyth:divergesFrom monomyth:RescueFromWithout ;
    monomyth:divergenceRationale """The return is entirely self-motivated, removing the need for external rescue. 
    This reflects a modern narrative emphasis on individual agency rather than dependence on external saviors or guides."""@en .

<walter-mitty/divergences/semiotic/internalized-threshold> a monomyth:SemioticDivergence ;
    rdfs:label "Internalized Threshold divergence"@en ;
    monomyth:divergenceOf <walter-mitty/stages/crossing-return-threshold> ;
    monomyth:divergesFrom monomyth:TheCrossingOfTheReturnThreshold ;
    monomyth:divergenceRationale """The threshold is no longer a boundary between incompatible worlds but a psychological shift within the same world. 
    Meaning is internalized rather than translated across ontological domains."""@en .

<walter-mitty/divergences/semiotic/world-collapse> a monomyth:SemioticDivergence ;
    rdfs:label "Collapse of Worlds divergence"@en ;
    monomyth:divergenceOf <walter-mitty/stages/master-of-two-worlds> ;
    monomyth:divergesFrom monomyth:MasterOfTheTwoWorlds ;
    monomyth:divergenceRationale """The distinction between ordinary and extraordinary worlds collapses entirely. 
    Instead of mastering two realms, the hero integrates imagination into reality, eliminating the dual structure assumed by the monomyth."""@en .

# --- Semiotic Divergences -----------------------------------------------------

<walter-mitty/divergences/semiotic/imagination-as-world> a monomyth:SemioticDivergence ;
    rdfs:label "Imagination as Proto-World divergence"@en ;
    monomyth:divergenceOf <walter-mitty/stages/threshold> ; # Added missing link
    monomyth:divergesFrom monomyth:TheCrossingOfTheFirstThreshold ;
    monomyth:divergenceRationale """The 'special world' initially exists as fantasy rather than geography, reversing the traditional structure."""@en .

<walter-mitty/divergences/semiotic/self-as-boon> a monomyth:SemioticDivergence ;
    rdfs:label "Self as Boon divergence"@en ;
    monomyth:divergenceOf <walter-mitty/stages/boon> ; # Added missing link
    monomyth:divergesFrom monomyth:TheUltimateBoon ;
    monomyth:divergenceRationale """The boon is not an external object but recognition of the self as meaningful."""@en .

<walter-mitty/divergences/semiotic/preexisting-engulfment> a monomyth:SemioticDivergence ;
    rdfs:label "Preexisting Engulfment divergence"@en ;
    monomyth:divergenceOf <walter-mitty/stages/belly-of-the-whale> ;
    monomyth:divergesFrom monomyth:TheBellyOfTheWhale ;
    monomyth:divergenceRationale """The 'whale' is not a physical or mythic space but an existential condition of alienation and passivity. 
    Engulfment is psychological and social rather than spatial, transforming the stage into a metaphor for an unactualized life."""@en .

# --- Narrative Divergences ----------------------------------------------------

<walter-mitty/divergences/narrative/absent-mentor> a monomyth:NarrativeDivergence ;
    rdfs:label "Absent Mentor divergence"@en ;
    monomyth:divergenceOf <walter-mitty/stages/supernatural-aid> ; # Added missing link
    monomyth:divergesFrom monomyth:SupernaturalAid ;
    monomyth:divergenceRationale """Guidance is indirect and constructed by the hero rather than delivered by a mentor."""@en .

# --- Sequential Divergence ----------------------------------------------------

<walter-mitty/divergences/sequential/soft-threshold> a monomyth:SequentialDivergence ;
    rdfs:label "Soft Threshold divergence"@en ;
    monomyth:divergenceOf <walter-mitty/stages/threshold> ; # Added missing link
    monomyth:divergesFrom monomyth:TheCrossingOfTheFirstThreshold ;
    monomyth:divergenceRationale """The transition into the special world is gradual rather than abrupt."""@en .

<walter-mitty/divergences/sequential/reversed-whale-order> a monomyth:SequentialDivergence ;
    rdfs:label "Reversed Whale Order divergence"@en ;
    monomyth:divergenceOf <walter-mitty/stages/belly-of-the-whale> ;
    monomyth:divergesFrom monomyth:TheBellyOfTheWhale ;
    monomyth:divergenceRationale """In the classical monomyth, the belly of the whale follows the crossing of the threshold and marks entry into the unknown. 
    In Walter Mitty, the hero begins the narrative already in a state of symbolic engulfment, 
    making the journey an emergence rather than a descent. This reverses the structural function of the stage."""@en .