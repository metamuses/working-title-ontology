@base <https://example.metamuses.org/graph/> .
@prefix exmpl: <https://example.metamuses.org/ontology#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix void: <http://rdfs.org/ns/void#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.metamuses.org/graph/> a void:Dataset ;
    dcterms:title "The dataset of the example ontology"@en ;
    dcterms:description "A dataset containing instantiations of classes and properties."@en ;
    dcterms:creator "Tommaso Barbato",
        "Nicol D'Amelio" ,
        "Maryam Dadras" ,
        "Martina Uccheddu" ;
    dcterms:conformsTo <https://example.metamuses.org/ontology> ;
    void:vocabulary <https://example.metamuses.org/ontology> ;
    void:dataDump <https://example.metamuses.org/1.0/graph.ttl> ;
    dcterms:created "2025-12-31"^^xsd:date ;
    dcterms:modified "2025-12-31"^^xsd:date ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:publisher <https://github.com/metamuses> ;
    rdfs:comment "A longer comment about the dataset and its purposes, components and else."@en ;
    rdfs:seeAlso <https://example.metamuses.org>,
        <https://github.com/metamuses/example> .

<item/exampleItem> a exmpl:Item ;
    rdfs:label "An example item."@en ;
    rdfs:comment "A longer comment about the item and its purposes, components and else."@en ;
    exmpl:createdBy <org/examplePerson> .

<org/examplePerson> a exmpl:Person ;
    rdfs:label "An example person."@en ;
    rdfs:comment "A longer comment about the person and its purposes, components and else."@en .
